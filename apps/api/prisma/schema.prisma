generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  pending
  active
  blocked
  deleted
}

enum PlayerProfileStatus {
  draft
  active
  limited
  blocked
}

enum PartnerVerificationStatus {
  draft
  pending_verification
  verified
  rejected
  suspended
  archived
}

enum VerificationRequestStatus {
  draft
  submitted
  in_review
  approved
  rejected
  needs_correction
}

enum BookingRequestStatus {
  draft
  pending
  confirmed
  rejected
  cancelled_by_player
  cancelled_by_partner
  expired
  completed
}

enum MatchRequestStatus {
  pending
  accepted
  declined
  cancelled
}

enum MatchRequestFormat {
  singles
  doubles
}

enum ScheduleExceptionType {
  closed
  custom_hours
  blocked
  custom_price
}

enum NotificationType {
  verification_submitted
  verification_approved
  verification_rejected
  verification_needs_correction
  booking_created
  booking_confirmed
  booking_rejected
  booking_cancelled
  booking_completed
  match_request_created
  match_request_accepted
  match_request_declined
  match_request_cancelled
}

enum NotificationRelatedEntityType {
  verification_request
  booking_request
  match_request
}

enum RoleKey {
  player
  partner
  admin
  superadmin
}

enum PartnerTypeKey {
  club
  school
  organizer
  store
  mixed
}

model User {
  id             String          @id @default(uuid()) @db.Uuid
  phone          String          @unique
  email          String?         @unique
  status         UserStatus      @default(pending)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")
  roles          UserRole[]
  sessions       UserSession[]
  settings       UserSetting?
  playerProfile  PlayerProfile?
  partnerProfile PartnerProfile?
  adminProfile   AdminProfile?
  uploadedFiles  File[]
  auditLogs      AuditLog[]
  bookingStatusChanges BookingRequestStatusHistory[]
  notifications  Notification[]
  initiatedMatchRequests MatchRequest[] @relation("match_request_initiator")
  receivedMatchRequests  MatchRequest[] @relation("match_request_opponent")

  @@map("users")
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  key         RoleKey   @unique
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  users       UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model UserSetting {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  locale               String   @default("ru")
  timezone             String   @default("Europe/Moscow")
  notificationsEnabled Boolean  @default(true) @map("notifications_enabled")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model City {
  id                 String                 @id @default(uuid()) @db.Uuid
  slug               String                 @unique
  name               String                 @unique
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  districts          District[]
  addresses          Address[]
  playerProfiles     PlayerProfile[]
  playerPreferences  PlayerPlayPreference[] @relation("preferred_city")
  partnerProfiles    PartnerProfile[]

  @@map("cities")
}

model District {
  id                 String                 @id @default(uuid()) @db.Uuid
  cityId             String                 @map("city_id") @db.Uuid
  slug               String
  name               String
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  city               City                   @relation(fields: [cityId], references: [id], onDelete: Cascade)
  addresses          Address[]
  playerProfiles     PlayerProfile[]
  playerPreferences  PlayerPlayPreference[] @relation("preferred_district")
  partnerProfiles    PartnerProfile[]

  @@unique([cityId, slug])
  @@unique([cityId, name])
  @@index([cityId])
  @@map("districts")
}

model File {
  id               String                 @id @default(uuid()) @db.Uuid
  originalName     String                 @map("original_name")
  storageBucket    String                 @map("storage_bucket")
  storageKey       String                 @unique @map("storage_key")
  mimeType         String                 @map("mime_type")
  sizeBytes        Int                    @map("size_bytes")
  uploadedByUserId String?                @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime               @default(now()) @map("created_at")
  uploadedByUser   User?                  @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  playerAvatars    PlayerProfile[]        @relation("player_avatar_file")
  verificationDocs VerificationDocument[]

  @@index([uploadedByUserId])
  @@map("files")
}

model PlayerProfile {
  id                 String                  @id @default(uuid()) @db.Uuid
  userId             String                  @unique @map("user_id") @db.Uuid
  status             PlayerProfileStatus     @default(draft)
  firstName          String                  @map("first_name")
  lastName           String                  @map("last_name")
  bio                String?
  ntrpSelfRating     Decimal?                @map("ntrp_self_rating") @db.Decimal(3, 1)
  cityId             String?                 @map("city_id") @db.Uuid
  districtId         String?                 @map("district_id") @db.Uuid
  avatarFileId       String?                 @unique @map("avatar_file_id") @db.Uuid
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  city               City?                   @relation(fields: [cityId], references: [id], onDelete: SetNull)
  district           District?               @relation(fields: [districtId], references: [id], onDelete: SetNull)
  avatarFile         File?                   @relation("player_avatar_file", fields: [avatarFileId], references: [id], onDelete: SetNull)
  visibilitySettings PlayerVisibilitySetting?
  playPreferences    PlayerPlayPreference?
  availabilitySlots  PlayerAvailabilitySlot[]
  bookingRequests    BookingRequest[]

  @@index([cityId])
  @@index([districtId])
  @@map("player_profiles")
}

model PlayerVisibilitySetting {
  id                            String        @id @default(uuid()) @db.Uuid
  playerProfileId               String        @unique @map("player_profile_id") @db.Uuid
  profileVisibleToAuthenticated Boolean       @default(true) @map("profile_visible_to_authenticated")
  showPhone                     Boolean       @default(false) @map("show_phone")
  showCity                      Boolean       @default(true) @map("show_city")
  showAvailability              Boolean       @default(true) @map("show_availability")
  createdAt                     DateTime      @default(now()) @map("created_at")
  updatedAt                     DateTime      @updatedAt @map("updated_at")
  playerProfile                 PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  @@map("player_visibility_settings")
}

model PlayerPlayPreference {
  id                  String        @id @default(uuid()) @db.Uuid
  playerProfileId     String        @unique @map("player_profile_id") @db.Uuid
  preferredFormats    String[]      @default([]) @map("preferred_formats")
  preferredDays       String[]      @default([]) @map("preferred_days")
  preferredTimes      String[]      @default([]) @map("preferred_times")
  preferredCityId     String?       @map("preferred_city_id") @db.Uuid
  preferredDistrictId String?       @map("preferred_district_id") @db.Uuid
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  playerProfile       PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  preferredCity       City?         @relation("preferred_city", fields: [preferredCityId], references: [id], onDelete: SetNull)
  preferredDistrict   District?     @relation("preferred_district", fields: [preferredDistrictId], references: [id], onDelete: SetNull)

  @@index([preferredCityId])
  @@index([preferredDistrictId])
  @@map("player_play_preferences")
}

model PlayerAvailabilitySlot {
  id              String        @id @default(uuid()) @db.Uuid
  playerProfileId String        @map("player_profile_id") @db.Uuid
  weekday         Int
  startTime       String        @map("start_time")
  endTime         String        @map("end_time")
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  playerProfile   PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  @@index([playerProfileId])
  @@map("player_availability_slots")
}

model PartnerType {
  id           String               @id @default(uuid()) @db.Uuid
  key          PartnerTypeKey       @unique
  name         String
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  profileTypes PartnerProfileType[]

  @@map("partner_types")
}

model PartnerProfile {
  id                   String                    @id @default(uuid()) @db.Uuid
  ownerUserId          String                    @unique @map("owner_user_id") @db.Uuid
  legalName            String                    @map("legal_name")
  brandName            String?                   @map("brand_name")
  description          String?
  contactPhone         String?                   @map("contact_phone")
  contactEmail         String?                   @map("contact_email")
  taxId                String?                   @map("tax_id")
  legalAddress         String?                   @map("legal_address")
  actualAddress        String?                   @map("actual_address")
  verificationStatus   PartnerVerificationStatus @default(draft) @map("verification_status")
  cityId               String?                   @map("city_id") @db.Uuid
  districtId           String?                   @map("district_id") @db.Uuid
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")
  ownerUser            User                      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  city                 City?                     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  district             District?                 @relation(fields: [districtId], references: [id], onDelete: SetNull)
  profileTypes         PartnerProfileType[]
  contacts             PartnerContact[]
  verificationRequests VerificationRequest[]
  venues               Venue[]
  bookingRequests      BookingRequest[]

  @@index([cityId])
  @@index([districtId])
  @@map("partner_profiles")
}

model Address {
  id          String    @id @default(uuid()) @db.Uuid
  cityId      String?   @map("city_id") @db.Uuid
  districtId  String?   @map("district_id") @db.Uuid
  line1       String    @map("line_1")
  line2       String?   @map("line_2")
  postalCode  String?   @map("postal_code")
  accessNotes String?   @map("access_notes")
  latitude    Decimal?  @db.Decimal(9, 6)
  longitude   Decimal?  @db.Decimal(9, 6)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  city        City?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  district    District? @relation(fields: [districtId], references: [id], onDelete: SetNull)
  venues      Venue[]

  @@index([cityId])
  @@index([districtId])
  @@map("addresses")
}

model Venue {
  id               String         @id @default(uuid()) @db.Uuid
  partnerProfileId String         @map("partner_profile_id") @db.Uuid
  addressId        String         @map("address_id") @db.Uuid
  name             String
  description      String?
  contactPhone     String?        @map("contact_phone")
  contactEmail     String?        @map("contact_email")
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  partnerProfile   PartnerProfile @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  address          Address        @relation(fields: [addressId], references: [id], onDelete: Restrict)
  courts           Court[]
  bookingRequests  BookingRequest[]

  @@index([partnerProfileId])
  @@index([addressId])
  @@map("venues")
}

model Court {
  id          String   @id @default(uuid()) @db.Uuid
  venueId     String   @map("venue_id") @db.Uuid
  name        String
  surfaceType String   @map("surface_type")
  isIndoor    Boolean  @default(false) @map("is_indoor")
  hasLighting Boolean  @default(false) @map("has_lighting")
  isActive    Boolean  @default(true) @map("is_active")
  notes       String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  venue       Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  bookingRequests BookingRequest[]
  scheduleTemplates CourtScheduleTemplate[]
  scheduleExceptions CourtScheduleException[]

  @@index([venueId])
  @@map("courts")
}

model PartnerProfileType {
  id               String         @id @default(uuid()) @db.Uuid
  partnerProfileId String         @map("partner_profile_id") @db.Uuid
  partnerTypeId    String         @map("partner_type_id") @db.Uuid
  createdAt        DateTime       @default(now()) @map("created_at")
  partnerProfile   PartnerProfile @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  partnerType      PartnerType    @relation(fields: [partnerTypeId], references: [id], onDelete: Cascade)

  @@unique([partnerProfileId, partnerTypeId])
  @@index([partnerTypeId])
  @@map("partner_profile_types")
}

model PartnerContact {
  id               String         @id @default(uuid()) @db.Uuid
  partnerProfileId String         @map("partner_profile_id") @db.Uuid
  type             String
  value            String
  label            String?
  isPrimary        Boolean        @default(false) @map("is_primary")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  partnerProfile   PartnerProfile @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)

  @@index([partnerProfileId])
  @@map("partner_contacts")
}

model AdminProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model VerificationRequest {
  id               String                    @id @default(uuid()) @db.Uuid
  partnerProfileId String                    @map("partner_profile_id") @db.Uuid
  status           VerificationRequestStatus @default(draft)
  comment          String?
  submittedAt      DateTime?                 @map("submitted_at")
  reviewedAt       DateTime?                 @map("reviewed_at")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")
  partnerProfile   PartnerProfile            @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  documents        VerificationDocument[]

  @@index([partnerProfileId])
  @@map("verification_requests")
}

model VerificationDocument {
  id                    String              @id @default(uuid()) @db.Uuid
  verificationRequestId String              @map("verification_request_id") @db.Uuid
  fileId                String              @map("file_id") @db.Uuid
  documentType          String              @map("document_type")
  createdAt             DateTime            @default(now()) @map("created_at")
  verificationRequest   VerificationRequest @relation(fields: [verificationRequestId], references: [id], onDelete: Cascade)
  file                  File                @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([verificationRequestId])
  @@index([fileId])
  @@map("verification_documents")
}

model BookingRequest {
  id                String               @id @default(uuid()) @db.Uuid
  playerProfileId   String               @map("player_profile_id") @db.Uuid
  partnerProfileId  String               @map("partner_profile_id") @db.Uuid
  venueId           String               @map("venue_id") @db.Uuid
  courtId           String               @map("court_id") @db.Uuid
  bookingDate       DateTime             @map("booking_date") @db.Date
  timeFrom          String               @map("time_from")
  timeTo            String               @map("time_to")
  durationMinutes   Int                  @map("duration_minutes")
  playersCount      Int                  @default(2) @map("players_count")
  commentFromPlayer String?              @map("comment_from_player")
  commentFromPartner String?             @map("comment_from_partner")
  status            BookingRequestStatus @default(draft)
  submittedAt       DateTime?            @map("submitted_at")
  respondedAt       DateTime?            @map("responded_at")
  cancelledAt       DateTime?            @map("cancelled_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  playerProfile     PlayerProfile        @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  partnerProfile    PartnerProfile       @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  venue             Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  court             Court                @relation(fields: [courtId], references: [id], onDelete: Cascade)
  statusHistory     BookingRequestStatusHistory[]

  @@index([playerProfileId])
  @@index([partnerProfileId])
  @@index([venueId])
  @@index([courtId])
  @@index([status, bookingDate])
  @@map("booking_requests")
}

model BookingRequestStatusHistory {
  id               String               @id @default(uuid()) @db.Uuid
  bookingRequestId String               @map("booking_request_id") @db.Uuid
  oldStatus        BookingRequestStatus? @map("old_status")
  newStatus        BookingRequestStatus @map("new_status")
  changedByUserId  String?              @map("changed_by_user_id") @db.Uuid
  comment          String?
  createdAt        DateTime             @default(now()) @map("created_at")
  bookingRequest   BookingRequest       @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  changedByUser    User?                @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([bookingRequestId])
  @@index([changedByUserId])
  @@map("booking_request_status_history")
}

model MatchRequest {
  id               String             @id @default(uuid()) @db.Uuid
  initiatorId      String             @map("initiator_id") @db.Uuid
  opponentId       String             @map("opponent_id") @db.Uuid
  status           MatchRequestStatus @default(pending)
  proposedDate     DateTime           @map("proposed_date") @db.Date
  proposedTimeFrom String             @map("proposed_time_from")
  proposedTimeTo   String             @map("proposed_time_to")
  format           MatchRequestFormat
  message          String?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  initiator        User               @relation("match_request_initiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  opponent         User               @relation("match_request_opponent", fields: [opponentId], references: [id], onDelete: Cascade)

  @@index([initiatorId, status, createdAt])
  @@index([opponentId, status, createdAt])
  @@map("match_requests")
}

model CourtScheduleTemplate {
  id                  String   @id @default(uuid()) @db.Uuid
  courtId             String   @map("court_id") @db.Uuid
  weekday             Int
  timeFrom            String   @map("time_from")
  timeTo              String   @map("time_to")
  slotDurationMinutes Int      @map("slot_duration_minutes")
  isOpen              Boolean  @default(true) @map("is_open")
  basePrice           Decimal? @map("base_price") @db.Decimal(10, 2)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  court               Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@index([courtId, weekday])
  @@map("court_schedule_templates")
}

model CourtScheduleException {
  id            String                @id @default(uuid()) @db.Uuid
  courtId       String                @map("court_id") @db.Uuid
  date          DateTime              @db.Date
  exceptionType ScheduleExceptionType @map("exception_type")
  timeFrom      String?               @map("time_from")
  timeTo        String?               @map("time_to")
  customPrice   Decimal?              @map("custom_price") @db.Decimal(10, 2)
  comment       String?
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  court         Court                 @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@index([courtId, date])
  @@map("court_schedule_exceptions")
}

model Notification {
  id                String                         @id @default(uuid()) @db.Uuid
  userId            String                         @map("user_id") @db.Uuid
  type              NotificationType
  title             String
  body              String
  relatedEntityType NotificationRelatedEntityType? @map("related_entity_type")
  relatedEntityId   String?                        @map("related_entity_id") @db.Uuid
  isRead            Boolean                        @default(false) @map("is_read")
  createdAt         DateTime                       @default(now()) @map("created_at")
  readAt            DateTime?                      @map("read_at")
  user              User                           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([relatedEntityType, relatedEntityId])
  @@map("notifications")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  action       String
  targetEntity String   @map("target_entity")
  targetId     String   @map("target_id")
  comment      String?
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  actorUser    User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetEntity, targetId])
  @@map("audit_logs")
}

model AuthPhoneChallenge {
  id         String    @id @default(uuid()) @db.Uuid
  phone      String
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([phone])
  @@map("auth_phone_challenges")
}
